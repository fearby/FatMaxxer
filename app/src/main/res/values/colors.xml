<!--
    res/values/colors.xml — Material 3 colour palette

    Generated using the Material Theme Builder:
    https://m3.material.io/theme-builder

    Seed colour: #1B6B4A (deep fitness green — evokes nature, zones, health)

    These are the LIGHT theme colours. The night/dark variants are in
    res/values-night/colors.xml (create that file with the dark palette).

    TIP: Run your own seed colour through the Material Theme Builder to get
    a full palette that matches your brand, then replace these values.
-->
<resources>

    <!-- Primary — deep green -->
    <color name="md_theme_primary">#1B6B4A</color>
    <color name="md_theme_on_primary">#FFFFFF</color>
    <color name="md_theme_primary_container">#A8F2C8</color>
    <color name="md_theme_on_primary_container">#002115</color>

    <!-- Secondary — muted teal -->
    <color name="md_theme_secondary">#4E6B5C</color>
    <color name="md_theme_on_secondary">#FFFFFF</color>
    <color name="md_theme_secondary_container">#D1F0DC</color>
    <color name="md_theme_on_secondary_container">#0C2119</color>

    <!-- Surface -->
    <color name="md_theme_surface">#F6FBF6</color>
    <color name="md_theme_on_surface">#181D19</color>
    <color name="md_theme_surface_variant">#DBE5DC</color>
    <color name="md_theme_on_surface_variant">#404942</color>

    <!-- Error -->
    <color name="md_theme_error">#BA1A1A</color>
    <color name="md_theme_on_error">#FFFFFF</color>

    <!-- Zone colours — used to tint the α1 hero card -->
    <!-- Fat burning zone (α1 > 0.75) — green -->
    <color name="zone_fat_burning">#A8F2C8</color>
    <!-- Aerobic zone (0.50 < α1 ≤ 0.75) — yellow/amber -->
    <color name="zone_aerobic">#FFF0A0</color>
    <!-- Anaerobic zone (α1 ≤ 0.50) — red -->
    <color name="zone_anaerobic">#FFCDD2</color>
    <!-- No data / waiting -->
    <color name="zone_waiting">#DBE5DC</color>

</resources>
